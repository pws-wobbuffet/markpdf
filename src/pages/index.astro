---
import App from '../components/App';
import '../styles/global.css';
import '../styles/preview.css';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="Write Markdown. Export PDF. Nothing leaves your browser." />
  <title>markpdf — Markdown to PDF, privately</title>
  <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&display=swap" rel="stylesheet" />
</head>
<body>
  <App client:only="react" />
</body>
</html>
